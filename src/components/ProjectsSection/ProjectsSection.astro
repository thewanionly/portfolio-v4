---
import { sanityClient } from 'sanity:client';

import { projectsSectionQuery } from '@/lib/sanity/queries';
import type { ProjectsSectionQueryResult } from '@/lib/sanity/queries';
import type { Project } from './ProjectsSection.types';
import { ProjectCarousel } from './ProjectCarousel';
import { ProjectGrid } from './ProjectGrid';

const projectsSection = await sanityClient.fetch<ProjectsSectionQueryResult>(projectsSectionQuery);

const projects: Project[] =
  projectsSection?.projects
    .filter((project) => project.isVisible !== false)
    .filter((project) => project.image?.asset?.url)
    .map((project) => ({
      id: project._key,
      imgSrc: project.image?.asset?.url || '',
      imgAlt: project.image?.alt || `${project.title} screenshot`,
      title: project.title,
      technologies: project.technologies,
      projectUrl: project.projectUrl,
      sourceCodeUrl: project.sourceCodeUrl,
    })) || [];
---

{
  projectsSection && projects.length > 0 && (
    <section id="projects" class="scroll-mt-10 md:scroll-mt-15 lg:scroll-mt-20">
      <div class="section-wrapper py-16">
        <h2 class="text-4xl md:text-5xl lg:text-6xl text-center md:text-start font-bold mb-10 md:mb-15 lg:mb-20">
          <a href="#projects">{projectsSection.title}</a>
        </h2>

        <div class="block md:hidden">
          <ProjectCarousel projects={projects} client:visible />
        </div>
        <div class="hidden md:block">
          <ProjectGrid projects={projects} client:visible />
        </div>
      </div>
      <div class="-mb-0.25 mt-16 text-background-secondary">
        <svg
          class="h-auto w-full"
          viewBox="0 0 1001 51"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M276.335 23.0009C167.075 22.9529 0.5 50.5664 0.5 50.5664H1000.5C1000.5 50.5664 891.737 8.51346 812.228 1.78471C697.762 -7.90236 641.186 43.2892 525.612 45.6108C427.173 47.5882 374.831 23.0442 276.335 23.0009Z"
            fill="currentColor"
          />
        </svg>
      </div>
    </section>
  )
}
