---
import { sanityClient } from 'sanity:client';

import { skillsSectionQuery } from '@/lib/sanity/queries';
import type { SkillsSectionQueryResult } from '@/lib/sanity/queries';
import { SkillsAccordion } from './SkillsAccordion';

const skillsSection = await sanityClient.fetch<SkillsSectionQueryResult>(skillsSectionQuery);
const categories =
  skillsSection?.categories?.filter(({ title, skills }) => title && skills.length > 0) ?? [];
---

{
  skillsSection && categories.length > 0 && (
    <section
      id="skills"
      class="relative overflow-hidden bg-background-secondary scroll-mt-10 md:scroll-mt-15 lg:scroll-mt-20"
    >
      <div class="pointer-events-none absolute -left-10 top-47 h-36 w-36 rounded-full bg-brand/35 blur-3xl" />
      <div class="pointer-events-none absolute bottom-47 right-0 h-32 w-32 rounded-full bg-brand/20 blur-3xl" />

      <div class="-mt-0.5 text-background">
        <svg
          class="h-auto w-full"
          viewBox="0 0 1440 72"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M0 40C142 24 255 12 374 12C522 12 632 34 756 34C884 34 990 10 1118 10C1236 10 1339 28 1440 24V0H0V40Z"
            fill="currentColor"
          />
        </svg>
      </div>

      <div class="section-wrapper relative py-16">
        <h2 class="text-4xl md:text-5xl lg:text-6xl text-center md:text-start font-bold mb-10 md:mb-15 lg:mb-20 text-balance">
          <a href="#skills">{skillsSection.title}</a>
        </h2>

        <SkillsAccordion categories={categories} client:visible />
      </div>

      <div class="-mb-0.5 text-background">
        <svg
          class="h-auto w-full"
          viewBox="0 0 1440 76"
          fill="none"
          xmlns="http://www.w3.org/2000/svg"
          aria-hidden="true"
        >
          <path
            d="M0 18C132 34 248 54 384 54C525 54 633 28 758 28C890 28 1003 56 1129 56C1239 56 1345 38 1440 22V76H0V18Z"
            fill="currentColor"
          />
        </svg>
      </div>
    </section>
  )
}
