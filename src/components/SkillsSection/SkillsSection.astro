---
import { sanityClient } from 'sanity:client';

import { skillsSectionQuery } from '@/lib/sanity/queries';
import type { SkillsSectionQueryResult } from '@/lib/sanity/queries';

const skillsSection = await sanityClient.fetch<SkillsSectionQueryResult>(skillsSectionQuery);
---

{
  skillsSection && (
    <section id="skills" class="scroll-mt-10 md:scroll-mt-15 lg:scroll-mt-20">
      <div class="section-wrapper py-16">
        <h2 class="text-4xl md:text-5xl lg:text-6xl text-center md:text-start font-bold mb-10 md:mb-15 lg:mb-20">
          <a href="#skills">{skillsSection.title}</a>
        </h2>
        <div class="grid 2xs:grid-cols-3 grid-cols-2 xs:grid-cols-4 sm:grid-cols-5 md:grid-cols-6 gap-x-4 gap-y-12.5">
          {skillsSection.skills.map(({ label, icon }) => (
            <div class="flex flex-col gap-3 items-center ">
              {icon?.asset?.url && (
                <img
                  class="size-10 md:size-12.5 object-contain"
                  src={icon.asset.url}
                  alt=""
                  aria-hidden="true"
                  loading="lazy"
                  decoding="async"
                />
              )}
              <span class="text-lg text-center">{label}</span>
            </div>
          ))}
        </div>
      </div>
    </section>
  )
}
