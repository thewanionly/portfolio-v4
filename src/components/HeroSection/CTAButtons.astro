---
import { buttonVariants } from '@/components/ui/button';
import { cn } from '@/lib/utils';
import type { HeroSectionQueryResult } from '@/lib/sanity/queries';

type CTAButton = NonNullable<HeroSectionQueryResult>['ctaButtons'][number];

const { buttons = [] } = Astro.props as {
  buttons?: CTAButton[];
};
---

<div class="w-full flex flex-col items-center md:items-start gap-4 md:gap-6">
  {
    buttons.length > 0 && (
      <div class="w-full flex gap-4 flex-wrap justify-center md:justify-start">
        {buttons.map((button) => {
          const isContactButton = /contact/i.test(button.label) || button.href === '#contact';
          const variant = isContactButton || button.variant === 'outline' ? 'outline' : 'default';

          return (
            <a
              href={button.href}
              target={button.openInNewTab ? '_blank' : undefined}
              rel={button.openInNewTab ? 'noreferrer noopener' : undefined}
              class={cn(
                buttonVariants({ variant }),
                'flex-1 max-w-[10rem] md:text-base md:h-10 md:px-6 md:has-[>svg]:px-4'
              )}
            >
              {button.label}
            </a>
          );
        })}
      </div>
    )
  }
  <!-- <button
    type="button"
    class={cn(
      buttonVariants({ variant: 'ghost' }),
      'md:text-base w-fit md:h-10 md:px-6 md:has-[>svg]:px-4'
    )}
  >
    Download Resume
  </button> -->
</div>
